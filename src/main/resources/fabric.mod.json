{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${mod_version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [
        "${mod_authors}"
    ],
    "contact": {
        "homepage": "https://modrinth.com/mod/${github_mod_name}",
        "issues": "https://github.com/${github_author}/${github_mod_name}/issues"
    },
    "license": "${mod_license}",
    "icon": "icon/icon.png",
    "environment": "${fabric_trick_side}",
    "entrypoints": {
        "main": [
	        "net.lopymine.dl.entrypoint.CommonEntrypoint"
        ],
        "client": [
	        "net.lopymine.dl.entrypoint.ClientEntrypoint"
        ]
    },
    "depends": {
	    "mossylib": ">=${mossylib}",
        "fabricloader": ">=${fabric_loader}",
        "minecraft": ">=${minecraft}",
        "java": ">=${java}",
        "${fabric_api_id}": "*"
    },
	"accessWidener": "${fabric_trick_accesswidener_id}",
	"mixins": [
		"${fabric_trick_mixin_configs}"
	]
}